@article{zendleCrossculturalPatternsMobile2023,
  title = {Cross-Cultural Patterns in Mobile Playtime: An Analysis of 118 Billion Hours of Human Data},
  shorttitle = {Cross-Cultural Patterns in Mobile Playtime},
  author = {Zendle, David and Flick, Catherine and Halgarth, Darel and Ballou, Nick and Demediuk, Simon and Drachen, Anders},
  year = {2023},
  month = jan,
  journal = {Scientific Reports},
  volume = {13},
  number = {1},
  pages = {386},
  publisher = {Nature Publishing Group},
  issn = {2045-2322},
  doi = {10.1038/s41598-022-26730-w},
  urldate = {2023-03-28},
  abstract = {Despite the prevalence of gaming as a human activity, the literature on playtime is uninformed by large-scale, high-quality data. This has led to an evidence-base in which the existence of specific cultural gaming cultures (e.g. exceptional levels of gaming in East Asian nations) are not well-supported by evidence. Here we address this evidence gap by conducting the world's first large-scale investigation of cross-cultural differences in mobile gaming via telemetry analysis. Our data cover 118 billion hours of playtime occurring in 214 countries and regions between October 2020 and October 2021. A cluster analysis establishes a data-driven set of cross-cultural groupings that describe differences in how the world plays mobile games. Despite contemporary arguments regarding Asian exceptionalism in terms of playtime, analysis shows that many East Asian countries (e.g., China) were not highly differentiated from most high-GDP Northern European nations across several measures of play. Instead, a range of previously unstudied and highly differentiated cross-cultural clusters emerged from the data and are presented here, showcasing the diversity of global gaming.},
  copyright = {2023 The Author(s)},
  langid = {english},
  keywords = {Health policy,Human behaviour},
  file = {/Users/thomashakman/Zotero/storage/Q86H8UBG/Zendle et al_2023_Cross-cultural patterns in mobile playtime.pdf}
}
