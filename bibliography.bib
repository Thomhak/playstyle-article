  shorttitle = {Interpretation of Changes in Health-Related Quality of Life},
  author = {Norman, Geoffrey R. and Sloan, Jeff A. and Wyrwich, Kathleen W.},
  year = {2003},
  month = may,
  journal = {Medical Care},
