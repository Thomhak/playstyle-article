  author = {Khazaal, Yasser and {van Singer}, Mathias and Chatton, Anne and Achab, Sophia and Zullino, Daniele and Rothen, Stephane and Khan, Riaz and Billieux, Joel and Thorens, Gabriel},
  year = {2014},
