}

@article{beanVideoGamersPersonality2016,
  title = {Video Gamers and Personality: {{A}} Five-Factor Model to Understand Game Playing Style},
  shorttitle = {Video Gamers and Personality},
  author = {Bean, Anthony and {Groth-Marnat}, Gary},
  year = {2016},
  journal = {Psychology of Popular Media Culture},
  volume = {5},
