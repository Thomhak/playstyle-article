# System files
.DS_Store
Thumbs.db

# R session files
.Rhistory
.RData
.Rproj.user/

# Quarto render outputs (regenerated from source)
/.quarto/
*_cache/
*_files/

# Rendered outputs (regenerated by quarto render)
*.html
*.pdf
*.tex
*.log
*.knit.md
*.typ
!_extensions/**/*.typ

# Word exports (regenerated by quarto render)
*.docx

# Keep final manuscript renders for readers
!manuscript.html
!manuscript.pdf
!manuscript.docx

# Temporary Office files
~$*

# Editor/IDE files
.vscode/
.cursor/
.luarc.json

# Claude worktree artifacts
.claude/

# Raw data (download from https://osf.io/cjd6z/files/4gp3r)
data/raw/ea/*.csv
data/raw/ea/*.xlsx

# Processed data (regenerated from preprocessing_new.qmd)
data/processed/*.csv

# Intermediate data (regenerated from preprocessing_new.qmd)
data/pvz_clean_5sd.csv
data/pvz_clean_6sd.csv
data/pvz_clean_6sd_final.csv
data/pvz_df_analysis_*.csv

# Keep directory structure
!data/raw/ea/.gitkeep
!data/processed/.gitkeep

# Model cache (large files, regenerated by manuscript.qmd)
output/models/*.rds
!output/models/.gitkeep

# Generated figures are tracked (small PNGs)
# figures/ is NOT ignored
